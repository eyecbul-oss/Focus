{
  "expo": {
    "name": "SezR Focus",
    "slug": "sezr-focus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "sezrfocus",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sezrmatematik.focus",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      },
      "permissions": [
        "INTERNET",
        "VIBRATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.sezrmatematik.focus",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ]
  }
}
